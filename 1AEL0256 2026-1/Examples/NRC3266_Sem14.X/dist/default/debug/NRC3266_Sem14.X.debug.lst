 17567                           ;	PR1WAY = ON, PRLOCKED bit can be cleared and set only once
 17568                           ;	Clock Switch Enable bit
 17569                           ;	CSWEN = ON, Writing to NOSC and NDIV is allowed
 17570                           ;	Fail-Safe Clock Monitor Enable bit
 17571                           ;	FCMEN = ON, Fail-Safe Clock Monitor enabled
 17572   300001                     	org	3145729
 17573   300001  FF                 	db	255
 17574                           
 17575                           ;Config register CONFIG3 @ 0x300002
 17576                           ;	MCLR Enable bit
