 17579                           ;	PWRTS = PWRT_64, PWRT set at 64ms
 17580                           ;	Multi-vector enable bit
 17581                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
 17582                           ;	IVTLOCK bit One-way set enable bit
 17583                           ;	IVT1WAY = ON, IVTLOCKED bit can be cleared and set only once
 17584                           ;	Low Power BOR Enable bit
