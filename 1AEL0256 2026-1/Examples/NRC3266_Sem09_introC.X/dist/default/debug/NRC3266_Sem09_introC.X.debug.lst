  1858                           ;	PWRTS = PWRT_64, PWRT set at 64ms
  1859                           ;	Multi-vector enable bit
  1860                           ;	MVECEN = ON, Multi-vector enabled, Vector table used for interrupts
  1861                           ;	IVTLOCK bit One-way set enable bit
